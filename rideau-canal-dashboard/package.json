{
  "name": "rideau-canal-dashboard", 
  // Project name (used by npm and for identification)

  "version": "1.0.0", 
  // Current version of the application

  "description": "Real-time monitoring dashboard for Rideau Canal Skateway", 
  // Short description of the project purpose

  "main": "server.js", 
  // Entry point of the Node.js application (backend starts here)

  "scripts": {
    "start": "node server.js", 
    // Command to start the app in production mode

    "dev": "nodemon server.js" 
    // Command to run app in development mode with auto-restart on file changes
  },

  "dependencies": {
    "@azure/cosmos": "^4.3.0", 
    // Azure Cosmos DB SDK for connecting and querying database

    "dotenv": "^16.6.1", 
    // Loads environment variables from .env file (e.g., keys, endpoints)

    "express": "^4.21.2" 
    // Web framework used to build API server and handle HTTP requests
  },

  "devDependencies": {
    "nodemon": "^3.1.10" 
    // Development tool that automatically restarts server when code changes
  }
}